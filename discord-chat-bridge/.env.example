PORT=3001

# Terrance's bot token (from /home/morpheus/Hackstuff/autoterrance/.env)
# REST API only — no gateway conflict with MoltX
DISCORD_BOT_TOKEN=

# Channel ID where threads will be created (must be a text channel Terrance watches)
DISCORD_CHANNEL_ID=

# Comma-separated allowed CORS origins
CORS_ORIGINS=https://mattcorwin.dev,http://localhost:5173

SESSION_TTL_MINUTES=30
RATE_LIMIT_MESSAGES_PER_MINUTE=10
